  <DataSources>
    <DataSource Name="dsIRCTC">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=RAJALAPTOP\SQLEXPRESS;Initial Catalog=IRCTC</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>7c7abb37-ed51-4be9-bf32-435e2c9b12a0</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="TicketData">
      <Query>
        <DataSourceName>dsIRCTC</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@PNRno">
            <Value>=Parameters!PNRno.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 
    p.PNRno,
    j.TrainNo,
    j.DeparturePlace,
    j.ArrivalPlace,
    p.Name,
    p.Sex,
    p.Age,
    j.BerthNo,
    a.Amount,
    j.DepartureDate AS ScheduleDeparture,
    j.ArrivalDate AS ScheduleArrival
FROM PassangerMaster p
INNER JOIN AccountMaster a ON p.PNRno = a.PNRno
INNER JOIN Journey_Details j ON p.PNRno = j.PNRno
WHERE p.PNRno = @PNRno</CommandText>
      </Query>
      <Fields>
        <Field Name="PNRno">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>PNRno</DataField>
        </Field>
        <Field Name="TrainNo">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>TrainNo</DataField>
        </Field>
        <Field Name="DeparturePlace">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>DeparturePlace</DataField>
        </Field>
        <Field Name="ArrivalPlace">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>ArrivalPlace</DataField>
        </Field>
        <Field Name="Name">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Name</DataField>
        </Field>
        <Field Name="Sex">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>Sex</DataField>
        </Field>
        <Field Name="Age">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>Age</DataField>
        </Field>
        <Field Name="BerthNo">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>BerthNo</DataField>
        </Field>
        <Field Name="Amount">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>Amount</DataField>
        </Field>
        <Field Name="ScheduleDeparture">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ScheduleDeparture</DataField>
        </Field>
        <Field Name="ScheduleArrival">
          <rd:TypeName>System.DateTime</rd:TypeName>
          <DataField>ScheduleArrival</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
